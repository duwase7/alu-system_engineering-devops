#!/usr/bin/env bash
# Configure nginx to run as nginx user on port 8080

NGINX_CONF="/etc/nginx/nginx.conf"
NGINX_USER="nginx"

# Ensure nginx user exists
id "$NGINX_USER" &>/dev/null || useradd -r -s /sbin/nologin "$NGINX_USER"

# Set nginx to run as nginx user
sed -i "s/^user .*/user $NGINX_USER;/" "$NGINX_CONF"

# Change port to 8080
sed -i 's/listen 80;/listen 8080;/g' /etc/nginx/sites-available/default
sed -i 's/listen \[::\]:80;/listen [::]:8080;/g' /etc/nginx/sites-available/default

# Stop nginx if running
pkill nginx 2>/dev/null

# Start nginx (IMPORTANT: as root)
nginx
