#!/usr/bin/env bash
# Configure nginx to run as nginx user and listen on port 8080

# Create nginx user if it doesn't exist
id nginx &>/dev/null || useradd -r -s /usr/sbin/nologin nginx

# Force nginx to use nginx user
sed -i 's/^user .*/user nginx;/' /etc/nginx/nginx.conf

# Ensure correct port in ALL configs
sed -i 's/listen 80;/listen 8080;/g' /etc/nginx/sites-available/default
sed -i 's/listen \[::\]:80;/listen [::]:8080;/g' /etc/nginx/sites-available/default
sed -i 's/listen 80 default_server;/listen 8080 default_server;/g' /etc/nginx/sites-available/default

# Stop nginx completely
pkill nginx 2>/dev/null

# Start nginx properly (as root)
nginx
